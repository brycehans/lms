# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Set to "true" to show the one-click "Quick login (demo)" panel on /auth/login.
# Requires the seeded accounts + shared password (seed.sql) to exist in the DB.
# Keep it off for any real deployment; gate a demo deploy at the edge instead.
NEXT_PUBLIC_DEMO_LOGINS=false
# Shared demo password used by the Quick-login panel. MUST match the password
# seed.sql hashes (its app.demo_password GUC, default "prophecy").
NEXT_PUBLIC_DEMO_PASSWORD=prophecy
