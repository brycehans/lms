# Copy this file to .env.local for local development:
#
#   cp .env.example .env.local
#
# The values below are the LOCAL Supabase stack's defaults — they are the same
# on every machine (the local publishable key is a fixed dev key, not a secret),
# so this file works out of the box with `pnpm dev`. For a hosted deploy, set the
# real project URL + publishable/anon key instead (see deploy-prep.md).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# Set to "true" to show the one-click "Quick login (demo)" panel on /auth/login.
# Requires the seeded accounts + shared password (seed.sql) to exist in the DB.
# Locally this is safe. On a hosted deploy it publishes working credentials,
# so only enable it behind the DEMO_BASIC_AUTH edge gate below.
NEXT_PUBLIC_DEMO_LOGINS=true
# Shared demo password used by the Quick-login panel. MUST match the password
# seed.sql hashes (its app.demo_password GUC, default "prophecy").
NEXT_PUBLIC_DEMO_PASSWORD=prophecy

# Optional site-wide HTTP Basic Auth gate (see proxy.ts). Leave UNSET locally.
# When set to "user:password", the middleware challenges every request before
# any app code runs — the edge gate that makes it safe to enable quick-login on
# a public demo without a paid Vercel plan. Server-only (no NEXT_PUBLIC_ prefix),
# so the password never reaches the client bundle.
# DEMO_BASIC_AUTH=reviewer:some-shared-secret
